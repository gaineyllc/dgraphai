# dgraph.ai environment variables
# Copy to .env and fill in values

# ── Required ──────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql+asyncpg://dgraphai:CHANGE_ME@localhost:5432/dgraphai

# Graph DB
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# Cache / Queue
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_URL=redis://localhost:6379/1
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=                   # openssl rand -hex 32
ENCRYPTION_KEY=               # openssl rand -base64 32 (for credential encryption)

# ── Application ───────────────────────────────────────────────────────────────

APP_URL=https://app.dgraph.ai
DGRAPHAI_ENABLE_DOCS=false    # set true for local dev

# ── Email (SMTP) ──────────────────────────────────────────────────────────────

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dgraph.ai

# ── Search (optional — falls back to graph CONTAINS queries) ──────────────────

MEILISEARCH_URL=              # http://localhost:7700
MEILISEARCH_MASTER_KEY=
OPENSEARCH_URL=               # https://localhost:9200

# ── Billing (optional) ────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=            # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=        # whsec_...
STRIPE_PRICE_PRO=             # price_...
STRIPE_PRICE_BUSINESS=        # price_...

# ── Observability (optional) ──────────────────────────────────────────────────

OTLP_ENDPOINT=                # http://jaeger:4317
AUDIT_WEBHOOK_URL=            # https://your-siem.com/ingest

# ── CVE Sync (optional — increases rate limit) ────────────────────────────────

NVD_API_KEY=                  # https://nvd.nist.gov/developers/request-an-api-key

# ── Circuit breaker tuning ────────────────────────────────────────────────────

GRAPH_CB_FAILURE_THRESHOLD=5
GRAPH_CB_WINDOW_SECS=60
GRAPH_CB_RESET_TIMEOUT_SECS=30
GRAPH_CB_QUERY_TIMEOUT_SECS=30
